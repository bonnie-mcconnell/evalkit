# MANIFEST.in - controls which files are included in the source distribution (.tar.gz).
#
# The wheel (.whl) only includes the evalkit/ package directory and is unaffected
# by this file. These rules ensure that anyone who downloads the sdist from PyPI
# and wants to run the examples has all the data they need without cloning the repo.
#
# Verified against: python -m build && tar -tzf dist/evalkit_research-*.tar.gz
# Expected: examples/data/*.jsonl, examples/walkthrough.ipynb, docs/*.md are present.

# Package typing marker (also declared in pyproject.toml package-data, belt-and-suspenders)
include evalkit/py.typed

# Demo datasets - required to run examples/full_workflow.py and examples/benchmark_audit.py
# without cloning the repo.
include examples/data/*.jsonl
include examples/data/README.md

# Jupyter notebook walkthrough (linked from README Binder badge)
include examples/walkthrough.ipynb
include examples/README.md

# Example scripts
include examples/*.py

# Documentation
include docs/*.md

# Project files users expect in a source distribution
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include SECURITY.md
include LICENSE
include CITATION.cff
